# SwitchBot API 認証情報
# アプリ → プロフィール → 設定 → 開発者向けオプション で取得（v1.1用）
SB_API_TOKEN=your_token_here
SB_API_SECRET=your_secret_here

# デバイスID（カンマ区切り、デバイスの数だけ列挙）
# SwitchBot アプリ → デバイス → 設定 → デバイス情報 で確認
DEVICE_IDS=id1,id2,id3,id4,id5,id6,id7,id8,id9,id10

# デバイス名（DEVICE_IDS と同じ順番でカンマ区切り）
DEVICE_NAMES=ペンペン,デスクライト,冷蔵庫,トイレ,ベッド,玄関充電,デスクチャージャー,テレビ他,洗濯機,ドライヤー

# Supabase 接続情報
# Supabase プロジェクト → Settings → API で取得
SUPABASE_URL=https://your-project-id.supabase.co
SUPABASE_SERVICE_ROLE_KEY=your_service_role_key_here
